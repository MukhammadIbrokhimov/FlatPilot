# Copy to .env and fill in the values you use.
# The .env file itself is gitignored; this example is safe to commit.

# Override where FlatPilot stores its state on the host (SQLite DB, geocode
# cache, scraper sessions). Defaults to ~/.flatpilot so the container shares
# state with a local install.
# FLATPILOT_DATA_DIR=

# Telegram notifications — filled in later, once the Telegram adapter lands.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# SMTP email notifications — filled in later, once the email adapter lands.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
